{
  "name": "@uswds-tailwind/turborepo-monorepo",
  "workspaces": [
    "apps/*",
    "packages/machines/*",
    "packages/theme",
    "packages/compat"
  ],
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "turbo run build",
    "build-packages": "turbo run build --filter='!website'",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy": "turbo run deploy",
    "publish": "turbo run publish",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "publish-beta": "pnpm build-packages && changeset version && changeset publish --tag beta && pnpm promote-to-latest",
    "promote-to-latest": "pnpm -r exec npm dist-tag add '$npm_package_name@$npm_package_version' latest",
    "test:browser": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@vitest/browser": "catalog:",
    "@zag-js/dom-query": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  }
}
