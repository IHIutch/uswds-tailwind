{
  "name": "@uswds-tailwind/turborepo-monorepo",
  "workspaces": [
    "apps/*",
    "packages/machines/*",
    "packages/theme",
    "packages/compat"
  ],
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy": "turbo run deploy",
    "publish": "turbo run publish",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "publish-packages": "changeset version && changeset publish --tag beta",
    "publish-packages-latest": "pnpm pre-exit && changeset version && changeset publish",
    "publish-packages-dual": "pnpm publish-packages-beta && pnpm publish-packages-latest",
    "pre-exit": "changeset pre exit",
    "pre-enter": "changeset pre enter beta",
    "release": "pnpm build && changeset publish",
    "test:browser": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@vitest/browser": "catalog:",
    "@zag-js/dom-query": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  }
}
