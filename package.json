{
  "name": "@uswds-tailwind/turborepo-monorepo",
  "workspaces": [
    "apps/*",
    "packages/machines/*",
    "packages/theme",
    "packages/compat"
  ],
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "turbo run build",
    "build-packages": "turbo run build --filter='!website'",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy": "turbo run deploy",
    "typecheck": "turbo run typecheck",
    "chgset:run": "changeset",
    "chgset:version": "changeset version",
    "chgset": "pnpm chgset:run && pnpm chgset:version",
    "test:browser": "vitest",
    "release": "changeset publish",
    "release:beta": "pnpm build-packages && changeset pre enter beta && changeset version && changeset publish && changeset pre exit",
    "postrelease": "git push --follow-tags && gh release create --draft --generate-notes \"v$(cat package.json | jq -r .version)\""
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@vitest/browser": "catalog:",
    "@zag-js/dom-query": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  }
}
