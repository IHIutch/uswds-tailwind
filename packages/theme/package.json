{
  "name": "@uswds-tailwind/theme",
  "type": "module",
  "version": "0.3.0-alpha.3",
  "description": "Tailwind CSS v4 theme with USWDS design tokens (colors, spacing, typography, breakpoints).",
  "author": "Jonathan Hutchison",
  "license": "MIT",
  "homepage": "https://uswds-tailwind.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IHIutch/uswds-tailwind.git",
    "directory": "packages/theme"
  },
  "bugs": "https://github.com/IHIutch/uswds-tailwind/issues",
  "keywords": [
    "uswds",
    "tailwindcss",
    "theme",
    "design-tokens",
    "design-system"
  ],
  "publishConfig": {
    "tag": "alpha"
  },
  "style": "src/index.css",
  "exports": {
    ".": {
      "style": "./src/index.css",
      "import": "./src/tailwind.config.ts",
      "require": "./src/tailwind.config.ts"
    },
    "./index.css": "./src/index.css",
    "./tailwind.config.ts": "./src/tailwind.config.ts"
  },
  "main": "src/tailwind.config.ts",
  "files": [
    "src/index.css",
    "src/tailwind.config.ts"
  ],
  "scripts": {
    "publint": "publint"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@tailwindcss/forms": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "tailwindcss-animate": "catalog:"
  },
  "optionalDependencies": {
    "@fontsource-variable/merriweather": "catalog:",
    "@fontsource-variable/open-sans": "catalog:",
    "@fontsource-variable/public-sans": "catalog:",
    "@fontsource-variable/roboto-mono": "catalog:",
    "@fontsource-variable/source-sans-3": "catalog:",
    "@iconify-json/fa-solid": "catalog:",
    "@iconify-json/fa6-brands": "catalog:",
    "@iconify-json/material-symbols": "catalog:",
    "@iconify/tailwind4": "catalog:"
  },
  "devDependencies": {
    "publint": "catalog:",
    "tailwindcss": "catalog:"
  }
}
